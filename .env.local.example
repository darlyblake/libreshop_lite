# Variables d'environnement pour LibreShop
# Copiez ce fichier vers .env.local et remplacez les valeurs par vos vraies configurations

# ⚠️ SÉCURITÉ: Ne jamais commiter ce fichier dans Git !
# Ajoutez .env.local à votre .gitignore

# Configuration Supabase (Obligatoire)
# Récupérez ces valeurs depuis votre dashboard Supabase > Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-jwt-token-here

# Configuration Cloudinary (Optionnel - pour les images)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=libreshop

# Configuration de l'application (Optionnel)
EXPO_PUBLIC_WEB_BASE_URL=https://your-domain.com
EXPO_PUBLIC_APP_NAME=LibreShop
EXPO_PUBLIC_APP_VERSION=1.0.0

# Configuration des features (Optionnel)
EXPO_PUBLIC_ENABLE_ANALYTICS=false
EXPO_PUBLIC_ENABLE_CRASH_REPORTING=true
EXPO_PUBLIC_DEBUG_MODE=false

# Configuration API (Optionnel)
EXPO_PUBLIC_API_TIMEOUT=30000
EXPO_PUBLIC_RETRY_ATTEMPTS=3
