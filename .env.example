SUPABASE_URL=
SUPABASE_SERVICE_KEY=
OPENAI_KEY=
BATCH_SIZE=50
# Variables d'environnement pour Supabase
# Remplacez les valeurs par celles de votre projet Supabase

EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Clé API pour Groc / Gemini utilisée par la recherche intelligente
# NOTE: Cette clé ne devrait pas être EXPO_PUBLIC_ car elle est exposée côté client
# Utilisez plutôt un endpoint côté serveur pour sécuriser cette clé
EXPO_PUBLIC_GROC_API_KEY=

EXPO_PUBLIC_WEB_BASE_URL=https://example.com

# Variables pour les scripts de test et admin
ADMIN_EMAIL=admin@libreshop.shop
ADMIN_PASSWORD=
ADMIN_NAME=Admin
TEST_PASSWORD=