SUPABASE_URL=
SUPABASE_SERVICE_KEY=
OPENAI_KEY=
BATCH_SIZE=50
# Variables d'environnement pour Supabase
# Remplacez les valeurs par celles de votre projet Supabase

EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Clés API pour Groc / Gemini - NE PAS EXPOSER CÔTÉ CLIENT
# Ces clés doivent être utilisées uniquement côté serveur
# Utilisez des endpoints serverless pour sécuriser ces appels
GROC_API_KEY=
GEMINI_API_KEY=

EXPO_PUBLIC_WEB_BASE_URL=https://example.com

# Variables pour les scripts de test et admin
ADMIN_EMAIL=admin@libreshop.shop
ADMIN_PASSWORD=
ADMIN_NAME=Admin
TEST_PASSWORD=